# Configuración de la Aplicación

# Base
APP_NAME=Cremería Francis
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost/cremeria-system

# Base de Datos
DB_HOST=localhost
DB_NAME=cremeria_db
DB_USER=root
DB_PASS=
DB_PORT=3306

# Seguridad
SESSION_TIMEOUT=3600
BCRYPT_COST=10

# Archivos
UPLOAD_MAX_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# Email (Futuro)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
